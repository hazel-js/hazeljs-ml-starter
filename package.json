{
  "name": "hazeljs-ml-starter",
  "version": "1.0.0",
  "description": "Comprehensive real-world ML starter using @hazeljs/ml - Sentiment analysis, model registry, training pipeline",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "train:sample": "ts-node src/scripts/train-with-sample-data.ts",
    "train:embedding": "ts-node src/scripts/train-embedding-model.ts",
    "test": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@hazeljs/core": "0.2.0-beta.38",
    "@hazeljs/ml": "0.2.0-beta.38",
    "@huggingface/transformers": "^3.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["hazeljs", "ml", "machine-learning", "sentiment-analysis", "starter"],
  "author": "HazelJS",
  "license": "Apache-2.0"
}
